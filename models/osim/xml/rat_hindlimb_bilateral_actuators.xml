	<ForceSet>
		<objects>
	<!-- Reserve actuators for all 22 coordinates.
	     CMC cost = sum((control_i / optimal_force_i)^2).
	     Sacrum reserves (residuals): high optimal_force because the model
	       has no trunk/forelimb muscles — residuals MUST compensate for
	       body weight (~1.25 N) and missing upper-body torques.
	       Rotational: 1.0 Nm, Translational: 10.0 N.
	     Joint reserves (hip, knee, ankle): low optimal_force (0.1) to
	       penalize reserve usage and push load onto muscles. -->

		<!-- Sacrum 6-DOF (residuals) -->
		<CoordinateActuator name="sacrum_pitch_reserve">
			<min_control>-Inf</min_control>
			<max_control>Inf</max_control>
			<coordinate>sacrum_pitch</coordinate>
			<optimal_force>1.5</optimal_force>
		</CoordinateActuator>
		<CoordinateActuator name="sacrum_roll_reserve">
			<min_control>-Inf</min_control>
			<max_control>Inf</max_control>
			<coordinate>sacrum_roll</coordinate>
			<optimal_force>1.5</optimal_force>
		</CoordinateActuator>
		<CoordinateActuator name="sacrum_yaw_reserve">
			<min_control>-Inf</min_control>
			<max_control>Inf</max_control>
			<coordinate>sacrum_yaw</coordinate>
			<optimal_force>1.5</optimal_force>
		</CoordinateActuator>
		<CoordinateActuator name="sacrum_x_reserve">
			<min_control>-Inf</min_control>
			<max_control>Inf</max_control>
			<coordinate>sacrum_x</coordinate>
			<optimal_force>10.0</optimal_force>
		</CoordinateActuator>
		<CoordinateActuator name="sacrum_y_reserve">
			<min_control>-Inf</min_control>
			<max_control>Inf</max_control>
			<coordinate>sacrum_y</coordinate>
			<optimal_force>10.0</optimal_force>
		</CoordinateActuator>
		<CoordinateActuator name="sacrum_z_reserve">
			<min_control>-Inf</min_control>
			<max_control>Inf</max_control>
			<coordinate>sacrum_z</coordinate>
			<optimal_force>10.0</optimal_force>
		</CoordinateActuator>

